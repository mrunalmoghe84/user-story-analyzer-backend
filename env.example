# Copy this file to .env and fill in your values
# Never commit .env to Git

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# A secret string the frontend must send in every request
# Generate one at: https://randomkeygen.com or run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=your-random-secret-here

# Your GitHub Pages URL (e.g. https://mrunalmoghe84.github.io)
# Use * during development to allow all origins
ALLOWED_ORIGIN=https://mrunalmoghe84.github.io

# Port (Render sets this automatically — leave as 3000 for local dev)
PORT=3000
